---
import Layout from '../../layouts/Layout.astro';
import PhotoGallery from '../../components/PhotoGallery.astro';
import { Image } from 'astro:assets';
import { getVillaImages } from '../../lib/galleries.js';

const villaImages = getVillaImages();
const hero = villaImages[0] ?? null;
// Alle weiteren Villa-Fotos (u. a. das Segelboot-Foto) als Galerie unter dem
// Hero zeigen, statt sie ungenutzt zu lassen.
const galleryImages = villaImages.slice(1);
---

<Layout title="Die Villa" description="Über die Villa Rosengarten und ihre Geschichte – 1920 erbaut, seit 2015 liebevoll restauriert.">
  <section class="wrap" style="padding-top:3rem;">
    <p class="eyebrow">About Villa Rosengarten &amp; Our Story</p>
    <h1>Über unsere Villa</h1>
    {hero ? (
      <Image
        class="villa-hero"
        src={hero}
        alt="Villa Rosengarten"
        widths={[600, 1000, 1600]}
        sizes="(max-width: 1100px) 100vw, 1040px"
        loading="eager"
      />
    ) : (
      <div class="card-image-placeholder" style="margin-bottom:1.5rem;">
        Foto der Villa folgt (src/images/villa/)
      </div>
    )}

    <div class="legal-content">
      <p>
        Fehmarn war oft unser Ziel, zum Kiten oder einfach um mit den Hunden am
        Strand zu sein.
      </p>
      <p>
        Bei einem unserer Besuche fiel uns die Villa ins Auge. Auf den ersten
        Blick haben wir uns in das Objekt verliebt und hatten 2015 die
        Gelegenheit, das Anwesen zu übernehmen. Mit aufwändiger Restauration und
        Umbauarbeiten ist eine moderne Umgebung in der 1920 erbauten Villa
        entstanden.
      </p>
      <p>
        Professionelles WLAN mit High-Speed-Internet ermöglicht unseren Gästen
        Remote Office in einer perfekten Umgebung. Der hohe Freizeitwert auf
        Fehmarn, nicht nur für Wassersportler, macht die Villa zum idealen Ziel
        für alle, die dem Alltag entkommen wollen.
      </p>
      <p>
        Unsere Fitness-Anlage und Sauna sind für individuell buchbare Termine
        geöffnet. Auch Haustiere sind bei uns willkommen.
      </p>
    </div>
  </section>

  {galleryImages.length > 0 && (
    <section class="wrap">
      <h2 class="section-title">Impressionen der Villa</h2>
      <PhotoGallery images={galleryImages} name="Villa Rosengarten" layout="masonry" />
    </section>
  )}

  <section class="wrap">
    <div class="legal-content">
      <h2>Die Wohnungen im Überblick</h2>
      <ul>
        <li><strong>Zwergenfee</strong> – im Anbau</li>
        <li><strong>Loft</strong> – im Souterrain</li>
        <li><strong>Romantika</strong> – im Hochparterre des Haupthauses</li>
        <li><strong>Sommerwind</strong> – mit Dachterrasse im Haupthaus</li>
      </ul>
    </div>
  </section>
</Layout>
