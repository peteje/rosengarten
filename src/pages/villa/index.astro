---
import Layout from '../../layouts/Layout.astro';
import PhotoGallery from '../../components/PhotoGallery.astro';
import { Image } from 'astro:assets';
import { getVillaImages } from '../../lib/galleries.js';
import heroVilla from '../../images/villa-hero.jpg';

const hero = heroVilla;
const galleryImages = getVillaImages();
---

<Layout title="Die Villa" description="Über die Villa Rosengarten und ihre Geschichte – 1920 erbaut, seit 2015 liebevoll restauriert.">
  <section class="wrap" style="padding-top:3rem;">
    <p class="eyebrow">Villa Rosengarten</p>
    <h1>Unsere Geschichte</h1>
    <Image
      class="villa-hero"
      src={hero}
      alt="Villa Rosengarten im Sommer"
      widths={[600, 1000, 1600]}
      sizes="(max-width: 1100px) 100vw, 1040px"
      loading="eager"
    />

    <div class="legal-content">
      <p>
        Fehmarn war für uns lange mehr als nur ein Reiseziel. Es war der Ort,
        an den wir immer wieder zurückkehrten – zum Kitesurfen, für
        ausgedehnte Spaziergänge mit unseren Hunden am Meer oder einfach, um
        die Ruhe, den Wind und die besondere Atmosphäre der Insel zu genießen.
      </p>
      <p>
        Bei einem dieser Besuche entdeckten wir die Villa Rosengarten. Schon
        beim ersten Anblick war klar: Dieses Haus hat eine Seele. Die
        Architektur, der alte Baumbestand und der Charme des Anwesens haben
        uns sofort begeistert. Als sich 2015 die Möglichkeit ergab, die Villa
        zu übernehmen, mussten wir nicht lange überlegen.
      </p>
      <p>
        Mit viel Leidenschaft, Liebe zum Detail und großem Respekt vor der
        Geschichte des Hauses haben wir die 1920 erbaute Villa aufwendig
        restauriert und modernisiert. Unser Ziel war es, den ursprünglichen
        Charakter zu bewahren und gleichzeitig einen Ort zu schaffen, an dem
        sich unsere Gäste rundum wohlfühlen – stilvoll, komfortabel und mit
        allen Annehmlichkeiten, die einen entspannten Aufenthalt ausmachen.
      </p>
      <p>
        Heute verbindet die Villa Rosengarten historische Eleganz mit
        modernem Wohnkomfort. Professionelles High-Speed-WLAN macht sie
        ebenso zum perfekten Rückzugsort für Remote Work wie für einen
        längeren Urlaub. Wer morgens mit Blick ins Grüne arbeitet und den
        Feierabend am Strand oder auf dem Wasser verbringt, erlebt eine ganz
        besondere Balance zwischen Arbeit und Erholung.
      </p>
      <p>
        Fehmarn bietet das ganze Jahr über außergewöhnliche Möglichkeiten:
        endlose Strände, Natur, Wassersport, Radwege und die Weite der
        Ostsee. Ob Kitesurfer, Radfahrer, Hundebesitzer, Naturliebhaber oder
        einfach Menschen, die dem Alltag für eine Weile entfliehen möchten –
        hier findet jeder seinen persönlichen Lieblingsplatz.
      </p>
      <p>
        Unsere kleine Fitness-Anlage und die Sauna stehen unseren Gästen nach
        individueller Terminvereinbarung zur Verfügung und laden dazu ein,
        Körper und Geist etwas Gutes zu tun. Selbstverständlich sind auch
        vierbeinige Familienmitglieder herzlich willkommen – denn wir wissen
        aus eigener Erfahrung, dass ein Urlaub erst dann vollkommen ist, wenn
        der beste Freund des Menschen dabei sein kann.
      </p>
      <p>
        Wir freuen uns darauf, Sie in der Villa Rosengarten willkommen zu
        heißen und unsere Begeisterung für diesen besonderen Ort mit Ihnen zu
        teilen.
      </p>
    </div>
  </section>

  {galleryImages.length > 0 && (
    <section class="wrap">
      <h2 class="section-title">Impressionen der Villa</h2>
      <PhotoGallery images={galleryImages} name="Villa Rosengarten" layout="masonry" />
    </section>
  )}

  <section class="wrap">
    <div class="legal-content">
      <h2>Die Wohnungen im Überblick</h2>
      <ul>
        <li><a href="/zwergenfee/"><strong>Zwergenfee</strong></a> – im Anbau</li>
        <li><a href="/loft/"><strong>Loft</strong></a> – im Souterrain</li>
        <li><a href="/romantika/"><strong>Romantika</strong></a> – im Hochparterre des Haupthauses</li>
        <li><a href="/sommerwind/"><strong>Sommerwind</strong></a> – mit Dachterrasse im Haupthaus</li>
      </ul>
    </div>
  </section>

  <section class="wrap">
    <div class="related-grid">
      <a class="related-card" href="/wintervilla/">
        <h3>Die Villa im Winter</h3>
        <p>Vereiste Küste, Kaminfeuer und stille Spaziergänge – Fehmarn hat auch außerhalb des Sommers seinen Reiz.</p>
        <span class="related-cta">Wintervilla entdecken →</span>
      </a>
      <a class="related-card" href="/sauna-fitness/">
        <h3>Sauna &amp; Fitness</h3>
        <p>Eigener Wellnessbereich für unsere Gäste – nach individueller Terminvereinbarung.</p>
        <span class="related-cta">Mehr erfahren →</span>
      </a>
    </div>
  </section>
</Layout>
