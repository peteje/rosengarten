---
import { Image, getImage } from 'astro:assets';

interface Props {
  images: ImageMetadata[];
  name: string;
  minTile?: number; // Mindestbreite einer Kachel in px (grid)
  layout?: 'grid' | 'masonry';
}

const { images, name, minTile = 200, layout = 'grid' } = Astro.props;

const fulls = await Promise.all(
  images.map((img) => getImage({ src: img, width: 2000, format: 'webp' }))
);
---

{
  images.length > 0 && (
    <>
      <div
        class:list={['gallery', layout === 'masonry' && 'gallery--masonry']}
        data-gallery
        style={`--min-tile:${minTile}px;`}
      >
        {images.map((img, i) => (
          <button
            type="button"
            class="gallery-item reveal"
            data-index={i}
            data-full={fulls[i].src}
            data-alt={`${name} – Foto ${i + 1}`}
            aria-label={`${name} – Foto ${i + 1} vergrößern`}
          >
            <Image
              src={img}
              alt={`${name} – Foto ${i + 1}`}
              widths={[400, 800]}
              sizes={`(max-width: 700px) 90vw, ${minTile}px`}
              loading={i < 3 ? 'eager' : 'lazy'}
            />
          </button>
        ))}
      </div>

      <div class="lightbox" data-lightbox hidden>
        <button class="lightbox-close" data-lb-close type="button" aria-label="Schließen">&times;</button>
        <button class="lightbox-nav lightbox-prev" data-lb-prev type="button" aria-label="Vorheriges Foto">&#8249;</button>
        <figure class="lightbox-figure">
          <img class="lightbox-img" data-lb-img src="" alt="" />
          <figcaption class="lightbox-counter" data-lb-counter></figcaption>
        </figure>
        <button class="lightbox-nav lightbox-next" data-lb-next type="button" aria-label="Nächstes Foto">&#8250;</button>
      </div>
    </>
  )
}

<script>
  // Lightbox: CSP-konform (keine Inline-Handler, kein externes JS).
  document.querySelectorAll('[data-gallery]').forEach((gallery) => {
    const box = gallery.parentElement?.querySelector('[data-lightbox]');
    if (!box) return;

    const imgEl = box.querySelector('[data-lb-img]') as HTMLImageElement;
    const counter = box.querySelector('[data-lb-counter]') as HTMLElement;
    const items = Array.from(
      gallery.querySelectorAll('.gallery-item')
    ) as HTMLElement[];
    let current = 0;

    const show = (i: number) => {
      current = (i + items.length) % items.length;
      const item = items[current];
      imgEl.src = item.dataset.full || '';
      imgEl.alt = item.dataset.alt || '';
      counter.textContent = `${current + 1} / ${items.length}`;
    };

    const open = (i: number) => {
      show(i);
      box.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
    };

    const close = () => {
      box.setAttribute('hidden', '');
      document.body.style.overflow = '';
    };

    items.forEach((item, i) => item.addEventListener('click', () => open(i)));
    box.querySelector('[data-lb-close]')?.addEventListener('click', close);
    box.querySelector('[data-lb-prev]')?.addEventListener('click', (e) => {
      e.stopPropagation();
      show(current - 1);
    });
    box.querySelector('[data-lb-next]')?.addEventListener('click', (e) => {
      e.stopPropagation();
      show(current + 1);
    });
    box.addEventListener('click', (e) => {
      if (e.target === box) close();
    });

    document.addEventListener('keydown', (e) => {
      if (box.hasAttribute('hidden')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(current - 1);
      else if (e.key === 'ArrowRight') show(current + 1);
    });

    let startX = 0;
    box.addEventListener(
      'touchstart',
      (e) => (startX = (e as TouchEvent).changedTouches[0].screenX),
      { passive: true }
    );
    box.addEventListener('touchend', (e) => {
      const dx = (e as TouchEvent).changedTouches[0].screenX - startX;
      if (Math.abs(dx) > 40) show(current + (dx < 0 ? 1 : -1));
    });
  });
</script>
