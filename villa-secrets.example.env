# Vorlage für die lokalen Smoobu-Zugangsdaten.
#
# So einrichten (einmalig):
#   cp villa-secrets.example.env ~/.villa-secrets.env
#   dann ~/.villa-secrets.env öffnen und die echten Werte eintragen.
#
# Diese Datei liegt bewusst AUSSERHALB des Repos (~/.villa-secrets.env) und wird
# NIEMALS committet. villa.sh lädt sie beim Build automatisch.
# Alternativer Pfad möglich über:  export VILLA_SECRETS=/pfad/zur/datei.env

SMOOBU_API_KEY=usr_live_DEIN_KEY
SMOOBU_API_SECRET=DEIN_SECRET
